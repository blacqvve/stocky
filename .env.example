# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_USER=stocky
POSTGRES_PASSWORD=stocky
POSTGRES_DB=stocky

# Path for PostgreSQL data persistence.
# Use a named volume (default): leave unset or set to "postgres_data"
# Use a host directory (bind mount): set to an absolute path, e.g. /mnt/data/postgres
POSTGRES_DATA_PATH=postgres_data

# Full connection string (used by Go API and migrate service)
DB_URL=postgres://stocky:stocky@db:5432/stocky?sslmode=disable

# ─── API ────────────────────────────────────────────────────────────────────
# Basic auth credentials (leave both empty to disable auth)
STOCKY_USER=admin
STOCKY_PASS=changeme

# CORS allowed origin (Next.js frontend URL)
CORS_ORIGIN=http://localhost:3000

# Port to expose the API on the host (default: 8080)
API_PORT=8080

# ─── Frontend ───────────────────────────────────────────────────────────────
# URL the browser uses to reach the API
# In docker-compose this should match API_PORT on localhost
NEXT_PUBLIC_API_URL=http://localhost:8080

# Port to expose the frontend on the host (default: 3000)
FRONTEND_PORT=3000
